<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} — {{ config.siteTitle }}{% else %}{{ config.siteTitle }}{% endif %}</title>
  <link rel="canonical" href="{{ config.siteUrl }}{{ page.url }}">
  <link rel="alternate" type="application/rss+xml" title="{{ config.siteTitle }}" href="/feed.xml">
  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>
  <header>
    <h1><a href="/">{{ config.siteTitle }}</a></h1>
    <h4>The eye of the bee holder.</h4>
    <a href="/feed.xml" class="rss">RSS</a>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    <nav class="navigation">
      <a href="/archive/">Archive</a>
    </nav>
    <p>&copy; {{ config.siteTitle }}</p>
  </footer>
</body>
</html>
