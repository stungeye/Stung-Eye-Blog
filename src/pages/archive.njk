---
layout: layouts/archive-index.njk
permalink: /archive/
title: Archive
---
<h1>Archive</h1>

{% for yearEntry in collections.daysByYear %}
  {% set year = yearEntry[0] %}
  {% set days = yearEntry[1] %}
  {% set months = [] %}
  {% for day in days %}
    {% set m = day.date | monthFromDate %}
    {% if m not in months %}
      {% set months = (months.push(m), months) %}
    {% endif %}
  {% endfor %}
  <p>
    <strong><a href="/archive/by_date/{{ year }}/">{{ year }}</a></strong> :
    {% for m in months | sort %}
      <a href="/archive/by_date/{{ year }}/{{ m }}/">{{ m | monthName }}</a>{% if not loop.last %} {% endif %}
    {% endfor %}
  </p>
{% endfor %}
