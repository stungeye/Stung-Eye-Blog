---
layout: layouts/base.njk
pagination:
  data: collections.days
  # Must match config.daysPerPage — Eleventy requires a literal here
  size: 10
  alias: days
  # collection is pre-sorted newest-first, no reversal needed
permalink: "{% if pagination.pageNumber == 0 %}/{% else %}/page/{{ pagination.pageNumber + 1 }}/{% endif %}"
# Empty title: homepage renders as just "Stung Eye" in <title> tag
title: ""
---
{% for day in days %}
<article class="day-block">
  <header class="day-block-header">
    <h2><a href="{{ day.url }}">{{ day.data.title }}</a></h2>
    <time datetime="{{ day.date | isoDate }}">{{ day.date | readableDateTime }}</time>
  </header>
  <div class="day-block-content">
    {{ day.content | safe }}
  </div>
</article>
{% if not loop.last %}<hr class="day-separator">{% endif %}
{% endfor %}

{% include "partials/pagination.njk" %}
